// Skill Usage Tracking — Architecture (C4 Model)
// Render: npx likec4 start docs/architecture/
// Export: npx likec4 export png docs/architecture/ -o docs/architecture/export/
// VS Code: install the LikeC4 extension for live preview

specification {
  element actor {
    style {
      shape person
    }
  }
  element system
  element container
  element database {
    style {
      shape storage
    }
  }
  element webapp {
    style {
      shape browser
    }
  }
  element script {
    style {
      shape component
    }
  }
}

model {
  developer = actor 'Developer' {
    description 'Uses Claude Code to write code'
  }

  claudeCode = system 'Claude Code CLI' {
    description 'Coding agent running on developer machine'
  }

  skillTelemetry = script 'Telemetry Client Script' {
    description 'TypeScript/Node.js client script invoked by the SessionEnd hook. Syncs skills with the server and submits invocation events. Name and install location TBD.'
  }

  localSkillStore = database 'Skill ID Cache' {
    description 'Local gitignored file: maps skill names to server-assigned IDs. Format TBD.'
  }

  telemetryServer = system 'Telemetry Server' {
    description 'Fastify + SQLite, hosted on Fly.io'

    fastapiServer = container 'Fastify Server' {
      technology 'TypeScript, Node.js, Fastify'
      description 'Handles ingest and serves the dashboard API and SPA'
    }

    sqliteDb = database 'SQLite Database' {
      technology 'SQLite'
      description '/data/telemetry.db on Fly.io persistent volume'
    }

    reactSpa = webapp 'React SPA' {
      technology 'React, Vite, TypeScript'
      description 'Dashboard SPA served by FastAPI at /'
    }

    fastapiServer -> sqliteDb 'reads/writes'
    fastapiServer -> reactSpa 'serves at /'
    reactSpa -> fastapiServer 'GET /api/projects/{id}/activity' {
      technology 'HTTP/JSON'
    }
  }

  developer -> claudeCode 'uses'
  claudeCode -> skillTelemetry 'SessionEnd hook invokes'
  skillTelemetry -> localSkillStore 'reads/writes skill IDs'
  skillTelemetry -> telemetryServer.fastapiServer 'POST /api/skills' {
    technology 'HTTP/JSON'
  }
  skillTelemetry -> telemetryServer.fastapiServer 'POST /api/events' {
    technology 'HTTP/JSON'
  }
  developer -> telemetryServer.reactSpa 'views dashboard' {
    technology 'HTTPS'
  }
}

views {
  view context {
    title 'System Context (C4 Level 1)'
    include developer, claudeCode, skillTelemetry, localSkillStore, telemetryServer
  }

  view containers of telemetryServer {
    title 'Container View (C4 Level 2)'
    include developer, claudeCode, skillTelemetry, localSkillStore, *
  }

  dynamic view sessionEndFlow {
    title 'SessionEnd Hook — Two-Step Flow'

    // Phase 1: Skill sync
    claudeCode -> skillTelemetry 'SessionEnd: invokes telemetry client script'
    skillTelemetry -> localSkillStore 'reads cached skill IDs'
    skillTelemetry -> telemetryServer.fastapiServer 'POST /api/skills (unregistered skills only)'
    skillTelemetry <- telemetryServer.fastapiServer 'returns server-assigned IDs'
    skillTelemetry -> localSkillStore 'persists new IDs (gitignored)'

    // Phase 2: Event submission
    skillTelemetry -> telemetryServer.fastapiServer 'POST /api/events (session invocations)'
  }
}
