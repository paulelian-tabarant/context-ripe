{
  "name": "@paulelian-tabarant/ripe",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ripe": "./dist/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "init:local": "npm run build && node dist/index.js init http://localhost:3000",
    "lint": "biome lint ./src ./tests",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.0.0",
    "nock": "^14.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
